# Rust build artifacts
/target/
**/target/

# Cargo lock file - uncomment if you don't want to version it
# For libraries: comment this out to commit Cargo.lock
# For binary applications: keep this to ignore Cargo.lock
# Cargo.lock

# Backup files generated by rustfmt and other tools
*.rs.bk
*.pdb

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS-specific files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Debug symbols
*.dSYM/
*.dSYM/**/*.dir
*.exe
*.exe.debug
*.out
*.app

# Testing and profiling coverage
*.profraw
*.profdata

# Dependency directories (if using local dependencies)
**/node_modules/

# Rust Analyzer
/rust-project.json

# Temporary files
*.tmp
*.temp
*.log

